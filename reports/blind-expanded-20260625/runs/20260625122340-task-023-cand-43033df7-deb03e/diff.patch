+function parseVersion(version) {
+  const match = /^(\d+)\.(\d+)\.(\d+)$/.exec(version);
+  return match ? match.slice(1).map(Number) : null;
+}
+
+function compareVersion(a, b) {
+  return a[0] - b[0] || a[1] - b[1] || a[2] - b[2];
+}
+
 function satisfiesCaret(version, range) {
   if (!range.startsWith('^')) return version === range;
-  const prefix = range.slice(1).split('.').slice(0, 2).join('.');
-  return version.startsWith(prefix + '.');
+
+  const current = parseVersion(version);
+  const lower = parseVersion(range.slice(1));
+  if (!current || !lower) return false;
+
+  const upper = lower[0] > 0
+    ? [lower[0] + 1, 0, 0]
+    : lower[1] > 0
+      ? [0, lower[1] + 1, 0]
+      : [0, 0, lower[2] + 1];
+
+  return compareVersion(current, lower) >= 0 && compareVersion(current, upper) < 0;
 }
 
 module.exports = { satisfiesCaret };
