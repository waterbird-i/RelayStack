+    const separatorIndex = line.indexOf('=');
+    const key = (
+      separatorIndex === -1 ? line : line.slice(0, separatorIndex)
+    ).trim();
+    const value = stripComment(
+      separatorIndex === -1 ? '' : line.slice(separatorIndex + 1).trim()
+    );
     env[key] = unquote(value);
   }
