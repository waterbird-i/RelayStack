 function satisfiesCaret(version, range) {
   if (!range.startsWith('^')) return version === range;
-  const prefix = range.slice(1).split('.').slice(0, 2).join('.');
-  return version.startsWith(prefix + '.');
+
+  const current = parseVersion(version);
+  const base = parseVersion(range.slice(1));
+  if (!current || !base) return false;
+
+  const upper = upperBound(base);
+  return compareVersion(current, base) >= 0 && compareVersion(current, upper) < 0;
+}
+
+function parseVersion(value) {
+  if (!/^\d+\.\d+\.\d+$/.test(value)) return null;
+  return value.split('.').map(Number);
+}
+
+function compareVersion(a, b) {
+  for (let i = 0; i < 3; i += 1) {
+    if (a[i] !== b[i]) return a[i] - b[i];
+  }
+  return 0;
+}
+
+function upperBound(version) {
+  const [major, minor, patch] = version;
+  if (major > 0) return [major + 1, 0, 0];
+  if (minor > 0) return [0, minor + 1, 0];
+  return [0, 0, patch + 1];
 }
 
 module.exports = { satisfiesCaret };
