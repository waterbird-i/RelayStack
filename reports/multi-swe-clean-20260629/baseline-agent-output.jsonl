n                inserted = varValue;\n            }\n        }\n        if (!inserted) {\n            containsUnresolvedVar = true;\n            return null;\n        }\n        return inserted;\n    };\n\n    const replaced = replaceVariablesMatches(source, matchReplacer);\n    if (containsUnresolvedVar) {\n        return null;\n    }\n    return replaced;\n}\n","exit_code":0,"status":"completed"}}
