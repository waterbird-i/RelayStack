+from urllib.parse import parse_qsl, urlencode, urlsplit, urlunsplit
+
+
 SECRET_HEADERS = {"authorization", "cookie", "x-api-key"}
+SECRET_QUERY_KEYS = {"token", "password", "secret"}
 
 
 def redact_headers(headers):
     return {
-        key: ("<redacted>" if key in SECRET_HEADERS else value)
+        key: ("<redacted>" if key.lower() in SECRET_HEADERS else value)
         for key, value in headers.items()
     }
 
 
 def redact_url(url):
-    return url
+    parts = urlsplit(url)
+    params = parse_qsl(parts.query, keep_blank_values=True)
+    if not any(key.lower() in SECRET_QUERY_KEYS for key, _ in params):
+        return url
+
+    redacted_params = [
+        (key, "<redacted>" if key.lower() in SECRET_QUERY_KEYS else value)
+        for key, value in params
+    ]
+    return urlunsplit(parts._replace(query=urlencode(redacted_params)))
