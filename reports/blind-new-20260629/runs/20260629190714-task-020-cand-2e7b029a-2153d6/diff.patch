 import xml.etree.ElementTree as ET
 
 
+FIELDS = ("tests", "failures", "errors", "skipped")
+CASE_CHILDREN = {"failures": "failure", "errors": "error", "skipped": "skipped"}
+
+
+def _count_cases(cases, field):
+    if field == "tests":
+        return len(cases)
+    return sum(len(case.findall(CASE_CHILDREN[field])) for case in cases)
+
+
